# --- Dashboard mode (v2) ---
# Only DASHBOARD_PASSWORD is needed for dashboard mode.
# All other settings are configured through the web UI.
DASHBOARD_PASSWORD=

# --- Legacy single-Kin mode (v1) ---
# These are only used when running `npm run start:legacy`.
KINDROID_API_KEY=your-kindroid-api-key
KINDROID_AI_ID=your-ai-id
LOCATION_NAME=Seabreak
LATITUDE=49.16
LONGITUDE=-123.94
TEMPERATURE_UNIT=celsius
WIND_SPEED_UNIT=kmh
UPDATE_HOURS=0,6,12,18
FORECAST_HOUR=7
LOCATION_REGION=British Columbia
TZ=America/Vancouver
